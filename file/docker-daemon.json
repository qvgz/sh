{
    "exec-opts": [
        "native.cgroupdriver=systemd"
    ],
    "log-driver": "json-file",
    "log-opts": {
        "max-size": "20m",
        "max-file": "3",
        "compress": "true"
    },
    "storage-driver": "overlay2",
    "live-restore": true,
    "features": {
        "buildkit": true
    },
    "icc": false,
    "ip-masq": true,
    "ipv6": false,
    "max-concurrent-downloads": 5,
    "max-concurrent-uploads": 5,
    "shutdown-timeout": 10
}